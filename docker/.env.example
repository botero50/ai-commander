# AI Commander Stream System - Environment Configuration

# Stream Configuration
STREAM_PORT=8080
STREAM_MATCHES=0
STREAM_LOG_INTERVAL=30

# AI Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=neural-chat:7b
CLAUDE_API_KEY=your-api-key-here

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Logging
LOG_LEVEL=info

# Grafana Configuration
GRAFANA_PASSWORD=secure-password-here

# Deployment Configuration
NODE_ENV=production
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE=ai-commander-stream
DOCKER_TAG=latest

# Performance Tuning
NODE_OPTIONS=--max-old-space-size=1024
