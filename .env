# ============================================================================
# AI Commander Arena Configuration
# ============================================================================

# Brain Configuration
# Format: "provider:model"
# Providers: ollama, openai, anthropic
# Examples:
#   ollama:mistral, ollama:llama2, ollama:tinyllama, ollama:neural-chat
#   openai:gpt-4, openai:gpt-3.5-turbo
#   anthropic:claude-3-opus-20240229, anthropic:claude-3-sonnet-20240229

# Tournament-Level Chess Configuration
# Dolphin (56B) was too slow and causing Ollama crashes
# Using Mistral (7B) vs Llama2:13b for balanced, fast games
BRAIN_P1=ollama:mistral:latest
BRAIN_P2=ollama:llama2:13b

# Brain Timeout (in milliseconds)
BRAIN_TIMEOUT=60000

# ============================================================================
# API Keys (Optional - only needed for non-Ollama providers)
# ============================================================================

# OpenAI API Key (for GPT-4, GPT-3.5-turbo)
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...

# Anthropic API Key (for Claude)
# Get your key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# Game Configuration
# ============================================================================

# Ollama Server URL (for local Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Game Startup Wait Time (in milliseconds)
STARTUP_WAIT=3000

# ============================================================================
# Arena Match Configuration
# ============================================================================

# Number of matches to run (0 = infinite)
# Set via --matches flag when running

# Decision Frequency (how often AI makes decisions)
# 1 = every tick (slow), 5 = every 5 ticks (faster), 10+ = very fast
DECISION_FREQUENCY=10

# ============================================================================
# Logging Configuration
# ============================================================================

# Log Level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# Advanced Configuration
# ============================================================================

# Enable streaming/broadcast server
ENABLE_BROADCAST=true
BROADCAST_PORT=8765

# HTTP API Server Port (for rankings, metrics, etc.)
API_PORT=8080

# ============================================================================
# EPIC 73: Continuous Arena Mode Configuration
# ============================================================================

# Match Restart Delay (in milliseconds) — Wait between games
# Default: 5000 (5 seconds)
# Streaming: 2000 (2 seconds for faster pacing)
# Tournament: 30000 (30 seconds for scheduled events)
MATCH_RESTART_DELAY_MS=5000

# Health Check Interval (in milliseconds) — Check Ollama health
# Default: 30000 (30 seconds)
# Streaming: 15000 (15 seconds for faster detection)
# Resilient: 10000 (10 seconds for aggressive monitoring)
HEALTH_CHECK_INTERVAL_MS=30000

# Ollama Retry Count — Number of times to retry connection
# Default: 5 (retries)
# Resilient: 10 (more aggressive recovery)
OLLAMA_RETRY_COUNT=5

# Ollama Retry Delay (in milliseconds) — Wait between retries
# Default: 5000 (5 seconds per retry, max 25s total)
# Fast: 2000 (faster recovery, 10s total)
OLLAMA_RETRY_DELAY_MS=5000

# Statistics File Location — Where to save arena statistics on shutdown
# Default: arena-statistics.json (in project root)
# Custom: /var/log/chess-arena/stats.json (for server deployment)
STATISTICS_PERSIST_FILE=arena-statistics.json
