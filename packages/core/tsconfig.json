{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false
  },
  "include": [
    "src/config/**/*.ts",
    "src/types/**/*.ts",
    "src/utils/**/*.ts",
    "src/tournament/elo-rating.ts",
    "src/index.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.skip.ts",
    "src/analytics/**/*.ts",
    "src/brain/**/*.ts",
    "src/commentary/**/*.ts",
    "src/streaming/**/*.ts",
    "dist",
    "node_modules"
  ],
  "references": [
    {
      "path": "../domain"
    }
  ]
}
