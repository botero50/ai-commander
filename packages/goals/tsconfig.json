{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "src/**/*",
    "!src/**/*.test.ts",
    "!src/**/*.test.js"
  ],
  "exclude": ["vitest.config.ts", 
    "node_modules",
    "dist",
    "tests",
    "src/**/*.test.ts",
    "**/*.test.ts"
  ],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../domain"
    }
  ]
}
