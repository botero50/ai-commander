{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.ts"
  ],
  "references": [
    {
      "path": "../brain"
    },
    {
      "path": "../core"
    },
    {
      "path": "../domain"
    },
    {
      "path": "../adapter"
    },
    {
      "path": "../engine"
    },
    {
      "path": "../goals"
    },
    {
      "path": "../planner"
    },
    {
      "path": "../decision"
    }
  ],
  "paths": {
    "@ai-commander/brain": ["../brain/dist/index.d.ts"]
  }
}
