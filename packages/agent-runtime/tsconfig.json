{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "dist",
    "node_modules"
  ],
  "references": [
    {
      "path": "../brain"
    },
    {
      "path": "../core"
    },
    {
      "path": "../domain"
    }
  ]
}
