{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "noEmit": false
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "**/*.test.ts"
  ],
  "references": [
    {
      "path": "../brain"
    },
    {
      "path": "../tournament-engine"
    },
    {
      "path": "../match-runner"
    },
    {
      "path": "../benchmark-reporter"
    }
  ]
}
