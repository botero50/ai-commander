{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@ai-commander/core": ["packages/core/src/index.ts"],
      "@ai-commander/domain": ["packages/domain/src/index.ts"],
      "@ai-commander/ecs": ["packages/ecs/src/index.ts"],
      "@ai-commander/engine": ["packages/engine/src/index.ts"],
      "@ai-commander/adapter": ["packages/adapter/src/index.ts"],
      "@ai-commander/decision": ["packages/decision/src/index.ts"],
      "@ai-commander/goals": ["packages/goals/src/index.ts"],
      "@ai-commander/planner": ["packages/planner/src/index.ts"],
      "@ai-commander/agent-runtime": ["packages/agent-runtime/src/index.ts"],
      "@ai-commander/fake-game-adapter": ["packages/fake-game-adapter/src/index.ts"],
      "@ai-commander/behavior-tree": ["packages/behavior-tree/src/index.ts"]
    }
  }
}
