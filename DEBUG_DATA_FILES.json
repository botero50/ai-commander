{
  "documentation": {
    "title": "Camera Debug Data Files",
    "description": "JSON files containing endpoint data used for camera target detection and position tracking",
    "created": "2026-07-13",
    "endpoints": {
      "world_state": {
        "url": "http://localhost:8080/api/debug/world-state",
        "description": "All game entities (units and buildings) with positions at tick 300",
        "file": "world-state-data.json",
        "purpose": "Extract civil centre positions for camera targets"
      },
      "camera_test": {
        "url": "http://localhost:8080/api/debug/camera-test",
        "description": "Extracted camera targets from civil centre positions",
        "file": "camera-test-data.json",
        "purpose": "Values sent to camera movement code"
      },
      "camera_position": {
        "url": "http://localhost:8080/api/debug/camera-position",
        "description": "Current camera position and target",
        "file": "Not yet saved",
        "purpose": "Monitor camera movement during test"
      }
    }
  },
  "example_data": {
    "world_state_endpoint": {
      "tick": 300,
      "p1Buildings": [
        {
          "template": "structures/cart/civil_centre",
          "x": 625,
          "z": 356
        }
      ],
      "p2Buildings": [
        {
          "template": "structures/kush/civil_centre",
          "x": 440,
          "z": 844
        }
      ],
      "note": "Full file contains all p1Units, p2Units arrays as well"
    },
    "camera_test_endpoint": {
      "tick": 300,
      "p1Pos": {
        "x": 625,
        "z": 356
      },
      "p2Pos": {
        "x": 440,
        "z": 844
      },
      "p1Building": {
        "template": "structures/cart/civil_centre",
        "x": 625,
        "z": 356
      },
      "p2Building": {
        "template": "structures/kush/civil_centre",
        "x": 440,
        "z": 844
      }
    },
    "camera_position_endpoint": {
      "p1Target": {
        "x": 625,
        "z": 356
      },
      "p2Target": {
        "x": 440,
        "z": 844
      },
      "message": "Camera targets from last test run. Check logs for real-time position updates."
    }
  },
  "how_to_fetch": {
    "powershell": {
      "world_state": "(Invoke-WebRequest -Uri 'http://localhost:8080/api/debug/world-state' -UseBasicParsing).Content | Out-File world-state-data.json -Encoding UTF8",
      "camera_test": "(Invoke-WebRequest -Uri 'http://localhost:8080/api/debug/camera-test' -UseBasicParsing).Content | Out-File camera-test-data.json -Encoding UTF8",
      "camera_position": "(Invoke-WebRequest -Uri 'http://localhost:8080/api/debug/camera-position' -UseBasicParsing).Content | Out-File camera-position-data.json -Encoding UTF8"
    },
    "bash": {
      "world_state": "curl -s http://localhost:8080/api/debug/world-state > world-state-data.json",
      "camera_test": "curl -s http://localhost:8080/api/debug/camera-test > camera-test-data.json",
      "camera_position": "curl -s http://localhost:8080/api/debug/camera-position > camera-position-data.json"
    }
  },
  "data_flow": {
    "step_1": {
      "name": "World State",
      "source": "http://localhost:8080/api/debug/world-state",
      "contains": "All game entities from tick 300",
      "example": {
        "p1Buildings[0]": "{ template: 'structures/cart/civil_centre', x: 625, z: 356 }",
        "p2Buildings[0]": "{ template: 'structures/kush/civil_centre', x: 440, z: 844 }"
      }
    },
    "step_2": {
      "name": "Extract Targets",
      "location": "run-arena-loop.ts line ~1010",
      "extracts": "Civil centre positions from world state",
      "code": "p1CivilCentres = worldState.agents.filter(a => a.customData.template.includes('civil') && a.controlledByPlayerId === '1')"
    },
    "step_3": {
      "name": "Camera Test Data",
      "source": "http://localhost:8080/api/debug/camera-test",
      "contains": "P1 and P2 targets extracted from step 2",
      "example": {
        "p1Pos": { "x": 625, "z": 356 },
        "p2Pos": { "x": 440, "z": 844 }
      }
    },
    "step_4": {
      "name": "Camera Movement",
      "function": "eventCamera.moveToEvent()",
      "receives": "p1Pos and p2Pos from camera test data",
      "sends_to": "Python camera controller with x,z coordinates"
    },
    "step_5": {
      "name": "Position Tracking",
      "logs": "Current position every 0.2 seconds",
      "shows": "[CAMERA TEST +0.2s] CURRENT: (512, 512) → TARGET: (625, 356) | Distance: 150 units"
    }
  },
  "key_coordinates_from_latest_run": {
    "Player_1": {
      "civil_centre_location": { "x": 625, "z": 356 },
      "civilization": "Carthage (cart)",
      "units_clustered_around": "x: 588-607, z: 163-363",
      "distance_from_center": "186 units"
    },
    "Player_2": {
      "civil_centre_location": { "x": 440, "z": 844 },
      "civilization": "Kush (kush)",
      "units_clustered_around": "x: 439-587, z: 819-883",
      "distance_from_center": "611 units"
    },
    "map_center": {
      "x": 512,
      "z": 512,
      "note": "Camera starts here before moving to P1 and P2"
    }
  },
  "troubleshooting": {
    "endpoint_not_responding": [
      "Make sure arena is running: npx tsx packages/zeroad-adapter/src/arena/run-arena-loop.ts",
      "Check that port 8080 is not blocked",
      "Wait at least 35 seconds for camera test to run (tick 300)"
    ],
    "coordinates_seem_wrong": [
      "Check world-state-data.json to verify civil centre positions",
      "Compare with camera-test-data.json to see extracted values",
      "Look at position tracking logs: grep 'CAMERA TEST' in console output",
      "Check if camera is moving in wrong direction - might indicate X,Z swap"
    ]
  },
  "files_in_this_session": {
    "world-state-data.json": "Full world state with all units and buildings",
    "camera-test-data.json": "Extracted camera targets",
    "CAMERA_DEBUG_ENDPOINTS.md": "Markdown documentation of endpoints",
    "DEBUG_DATA_FILES.json": "This file - complete reference guide",
    "get-debug-data.ps1": "PowerShell script to fetch endpoints",
    "get-debug-data.sh": "Bash script to fetch endpoints"
  }
}
