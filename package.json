{
  "name": "ai-commander",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AI Commander - Framework for building AI-controlled strategy game agents",
  "keywords": [
    "ai",
    "strategy-games",
    "agents",
    "planning",
    "decision-making",
    "game-development",
    "autonomous-agents",
    "framework"
  ],
  "author": "Anthropic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/ai-commander"
  },
  "bugs": {
    "url": "https://github.com/anthropics/ai-commander/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:arena": "tsc -b packages/fake-game-adapter",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "doctor": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "launch-demo": "node demo/launch-demo.js",
    "demo": "npm run build && node demo/simple-demo.js",
    "replay": "node demo/replay-demo.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "open": "^10.2.0"
  }
}
